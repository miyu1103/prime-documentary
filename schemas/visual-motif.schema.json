{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prime-documentary.local/schemas/visual-motif.schema.json",
  "title": "PD Reusable Visual Motif",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "motif_id",
    "motif",
    "source",
    "rights_basis",
    "verified_at"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "motif_id": { "type": "string", "pattern": "^MOT-[0-9]{4}$" },
    "motif": { "type": "string" },
    "mood": { "type": "string" },
    "orientation": { "enum": ["landscape", "portrait", "square"] },
    "sref": { "type": ["string", "null"] },
    "midjourney_prompt": { "type": "string" },
    "source": { "enum": ["midjourney", "licensed", "other"] },
    "asset_uri": { "type": ["string", "null"] },
    "content_hash": { "type": ["string", "null"] },
    "rights_basis": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "reuse_count": { "type": "integer", "minimum": 0 },
    "last_used_episode": { "type": ["string", "null"] },
    "verified_at": { "type": "string", "format": "date" },
    "notes": { "type": "string" }
  }
}
