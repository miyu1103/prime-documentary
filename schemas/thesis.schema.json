{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prime-documentary.local/schemas/thesis.schema.json",
  "type": "object",
  "additionalProperties": false,
  "title": "Documentary Thesis",
  "required": [
    "thesis_id",
    "episode_id",
    "revision",
    "common_belief",
    "hidden_structure",
    "final_thesis",
    "viewer_promise",
    "stakes",
    "counterargument",
    "status"
  ],
  "properties": {
    "thesis_id": {
      "type": "string"
    },
    "episode_id": {
      "type": "string"
    },
    "revision": {
      "type": "string"
    },
    "common_belief": {
      "type": "string"
    },
    "hidden_structure": {
      "type": "string"
    },
    "final_thesis": {
      "type": "string",
      "minLength": 30
    },
    "viewer_promise": {
      "type": "string"
    },
    "stakes": {
      "type": "string"
    },
    "counterargument": {
      "type": "string"
    },
    "claim_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk_class": {
      "enum": [
        "R0",
        "R1",
        "R2",
        "R3",
        "R4"
      ]
    },
    "status": {
      "enum": [
        "draft",
        "approved",
        "rejected",
        "stale"
      ]
    }
  }
}
