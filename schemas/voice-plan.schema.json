{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prime-documentary.local/schemas/voice-plan.schema.json",
  "type": "object",
  "additionalProperties": false,
  "title": "Voice Plan",
  "required": [
    "voice_plan_id",
    "episode_id",
    "script_revision",
    "voice_profile",
    "chunks"
  ],
  "properties": {
    "voice_plan_id": {
      "type": "string"
    },
    "episode_id": {
      "type": "string"
    },
    "script_revision": {
      "type": "string"
    },
    "voice_profile": {
      "type": "string"
    },
    "mode": {
      "enum": [
        "draft",
        "master"
      ]
    },
    "voice_id": {
      "comment": "Optional. Provider voice identifier (e.g. ElevenLabs). Ch1 narrator = Brian nPczCjzI2devNBz1zQrb.",
      "type": "string"
    },
    "model_id": {
      "comment": "Optional. Provider TTS model identifier (e.g. eleven_multilingual_v2).",
      "type": "string"
    },
    "delivery_legend": {
      "comment": "Optional. Human-readable explanation of the calm/building/intense delivery markers (decisions/0004).",
      "type": "string"
    },
    "pronunciation_keys_global": {
      "comment": "Optional. Episode-wide pronunciation guide applied across chunks.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "chunks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "chunk_id",
          "span_ids",
          "spoken_text",
          "target_seconds"
        ],
        "properties": {
          "delivery": {
            "comment": "Optional. Dynamic-delivery marker (decisions/0004): calm baseline / building tension / intense peak.",
            "enum": [
              "calm",
              "building",
              "intense"
            ]
          },
          "scene_id": {
            "type": "string"
          },
          "section": {
            "type": "string"
          },
          "chunk_id": {
            "type": "string"
          },
          "span_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "spoken_text": {
            "type": "string"
          },
          "context_before": {
            "type": "string"
          },
          "context_after": {
            "type": "string"
          },
          "pronunciation_keys": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "target_seconds": {
            "type": "number",
            "minimum": 0.2
          },
          "emotion": {
            "type": "string"
          },
          "revision_risk": {
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        }
      }
    }
  }
}
