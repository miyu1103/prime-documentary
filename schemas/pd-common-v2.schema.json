{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prime-documentary.local/schemas/pd-common-v2.schema.json",
  "title": "PD Common V2",
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 160
    },
    "revision": {
      "type": "string",
      "pattern": "^v[0-9]{3,}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "uri": {
      "type": "string",
      "minLength": 1
    },
    "hash": {
      "type": "string",
      "pattern": "^(sha256:)?[a-fA-F0-9]{64}$"
    },
    "risk": {
      "type": "string",
      "enum": [
        "R0",
        "R1",
        "R2",
        "R3",
        "R4"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "S0",
        "S1",
        "S2",
        "S3",
        "S4",
        "S5"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "valid",
        "approved",
        "rejected",
        "stale",
        "blocked",
        "superseded"
      ]
    },
    "artifact_ref": {
      "type": "object",
      "required": [
        "artifact_id",
        "revision",
        "uri",
        "sha256"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/id"
        },
        "revision": {
          "$ref": "#/$defs/revision"
        },
        "uri": {
          "$ref": "#/$defs/uri"
        },
        "sha256": {
          "$ref": "#/$defs/hash"
        },
        "media_type": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "created_at",
        "producer",
        "input_revisions"
      ],
      "properties": {
        "created_at": {
          "$ref": "#/$defs/timestamp"
        },
        "producer": {
          "type": "string"
        },
        "prompt_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "prompt_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "model_profile": {
          "type": [
            "string",
            "null"
          ]
        },
        "provider_request_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "input_revisions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "config_revision": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  }
}
