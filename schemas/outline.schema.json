{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prime-documentary.local/schemas/outline.schema.json",
  "type": "object",
  "additionalProperties": false,
  "title": "Documentary Outline",
  "required": [
    "outline_id",
    "episode_id",
    "revision",
    "hook",
    "chapters",
    "ending"
  ],
  "properties": {
    "outline_id": {
      "type": "string"
    },
    "episode_id": {
      "type": "string"
    },
    "revision": {
      "type": "string"
    },
    "hook": {
      "type": "object",
      "required": [
        "anomaly",
        "promise",
        "stakes"
      ],
      "properties": {
        "anomaly": {
          "type": "string"
        },
        "promise": {
          "type": "string"
        },
        "stakes": {
          "type": "string"
        }
      }
    },
    "chapters": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": [
          "chapter_id",
          "title",
          "function",
          "question_opened",
          "question_answered",
          "claim_ids",
          "target_seconds"
        ],
        "properties": {
          "chapter_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "function": {
            "type": "string"
          },
          "question_opened": {
            "type": [
              "string",
              "null"
            ]
          },
          "question_answered": {
            "type": [
              "string",
              "null"
            ]
          },
          "claim_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "target_seconds": {
            "type": "integer",
            "minimum": 15
          },
          "visual_opportunities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "ending": {
      "type": "object",
      "required": [
        "payoff",
        "resonance"
      ],
      "properties": {
        "payoff": {
          "type": "string"
        },
        "resonance": {
          "type": "string"
        }
      }
    }
  }
}
