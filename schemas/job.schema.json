{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prime-documentary.local/schemas/job.schema.json",
  "title": "PD Job",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "job_id",
    "episode_id",
    "stage",
    "status",
    "idempotency_key",
    "input_revisions",
    "attempt",
    "max_attempts",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "job_id": {
      "type": "string",
      "minLength": 8
    },
    "episode_id": {
      "type": "string",
      "pattern": "^PD-[0-9]{4}-[0-9]{3}-[a-z0-9-]+$"
    },
    "stage": {
      "type": "string",
      "minLength": 3
    },
    "status": {
      "enum": [
        "queued",
        "leased",
        "running",
        "succeeded",
        "failed_retryable",
        "failed_terminal",
        "blocked",
        "awaiting_approval",
        "cancelled",
        "superseded",
        "dead_letter"
      ]
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 16
    },
    "input_revisions": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^v[0-9]{3}$"
      }
    },
    "output_artifact_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "attempt": {
      "type": "integer",
      "minimum": 0
    },
    "max_attempts": {
      "type": "integer",
      "minimum": 1
    },
    "lease_owner": {
      "type": [
        "string",
        "null"
      ]
    },
    "lease_expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "provider_request_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "estimated_cost": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "amount",
        "currency"
      ],
      "properties": {
        "amount": {
          "type": "number",
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        }
      }
    },
    "actual_cost": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "amount",
        "currency"
      ],
      "properties": {
        "amount": {
          "type": "number",
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        }
      }
    },
    "error_class": {
      "type": [
        "string",
        "null"
      ]
    },
    "error_message": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "started_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "finished_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  }
}
