# Copy to `.env` (git-ignored) and fill in real values there. THIS FILE: variable NAMES only,
# never real secrets (rules/03, check_secrets.py). Paid providers are gated: the adapters refuse
# paid calls unless explicitly confirmed + within budget. Auth checks below are free/minimal.

# --- Research: CourtListener (free API, token-gated) ---
COURTLISTENER_TOKEN=

# --- Audio: ElevenLabs (metered/paid) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Video: Runway (subscription + credits, paid) ---
RUNWAY_API_KEY=

# --- Publish: YouTube Data API (OAuth; uploads are a gated side effect) ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
